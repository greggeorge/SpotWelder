	(text "Note 1: \n\nPressing both Up and Down together will enter into\nsetup mode allowing the default time period for Up\nand Down button presses to be changed.  Potentially\nyou will also be able to set a 'pre weld' period to \ninitially heat the metal before the final weld.\n\nThe Weld button selects the mode while in setup mode.\n\nPressing Up and Down buttons a second time return you\nto normal operation"
		(exclude_from_sim no)
		(at 113.284 178.816 0)
		(effects
			(font
				(face "0xProto Nerd Font Mono")
				(size 1.27 1.27)
				(bold yes)
			)
			(justify left)
		)
		(uuid "4927c898-d8e1-44e3-9e20-17edc9ebde5f")
	)
